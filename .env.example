# Copy to .env (gitignored). Every value below is for testing only.
# These are Anvil's well known, public dev keys. Never use them on a real network.

# Anvil account 0, used as the deployer and the MVP solver.
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
SOLVER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

RPC_URL=http://localhost:8545
CHAIN_ID=31337
DATABASE_URL=postgres://crossbook:crossbook@localhost:5432/crossbook

# Matching mode: continuous (cross on arrival, the default) or batch (collect
# over a window and clear each pair at one uniform price). BATCH_INTERVAL is the
# window length in seconds, used only in batch mode.
MATCHING_MODE=continuous
BATCH_INTERVAL=5
